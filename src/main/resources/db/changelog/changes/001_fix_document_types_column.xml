<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001_fix_document_types_column" author="alina">
        <renameColumn tableName="document_types"
                      oldColumnName="xsd_schema"
                      newColumnName="xsd_schema_old"/>

        <addColumn tableName="document_types">
            <column name="xsd_schema" type="text"/>
        </addColumn>

        <dropColumn tableName="document_types" columnName="xsd_schema_old"/>
    </changeSet>

</databaseChangeLog>